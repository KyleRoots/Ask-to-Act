# Dependencies and build outputs are regenerated inside the image.
**/node_modules
**/dist
**/*.tsbuildinfo

# Version control and agent/workspace metadata.
.git
.gitignore
.agents
.cursor

# Non-application assets not needed to build or run the server.
exports
attached_assets
artifacts/**/.replit-artifact

# Misc local files.
*.log
.DS_Store
Thumbs.db
