modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3001

[[ports]]
localPort = 5003
externalPort = 3002

[[ports]]
localPort = 5004
externalPort = 3003

[[ports]]
localPort = 5005
externalPort = 4200

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 8081

[[ports]]
localPort = 8096
externalPort = 8000

[[ports]]
localPort = 8097
externalPort = 6000

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 18522
externalPort = 5173

[[ports]]
localPort = 21146
externalPort = 6800

[[ports]]
localPort = 23744
externalPort = 8008

[[ports]]
localPort = 25265
externalPort = 9000

[userenv]

[userenv.shared]

[nix]
channel = "stable-25_05"
